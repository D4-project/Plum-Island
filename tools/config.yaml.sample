IN_MEILI_URL: "http://localhost:7800"
IN_MEILI_API_KEY: "thisneedtobechangedinproduction"
OUT_MEILI_URL: "http://localhost:7800"
OUT_MEILI_API_KEY: "thisneedtobechangedinproduction"
INDEX_NAME: "plum"

# Source KV for Reading 
IN_KVROCKS_PORT: 6666
IN_KVROCKS_HOST: localhost
# Optional when IN_KVROCKS requires auth.
IN_KVROCKS_PASSWORD: ""

# Kvrocks backup settings used by backup_kvrocks.py.
KVROCKS_BACKUP_DIR: "/var/lib/kvrocks/backup"
KVROCKS_BACKUP_REMOTE_USER: "backup"
KVROCKS_BACKUP_REMOTE_HOST: "backup.example.com"
KVROCKS_BACKUP_REMOTE_BASE_DIR: "/data/backups/kvrocks"
KVROCKS_BACKUP_RETENTION_DAYS: 14
KVROCKS_BACKUP_WAIT_SECONDS: 5

# Dest KV for writing
OUT_KVROCKS_PORT: 6666
OUT_KVROCKS_HOST: localhost

# Optional last_fqdns.py --learn regexes.
# Matching FQDNs are imported into Plum targets only when they resolve.
last_fqdns_learn:
  - ".lu$"

ONLINETLD: false
TLDADD:
  - "local"
# Optional when ONLINETLD is false:
# TLDS:
#   - "com"
#   - "net"
#   - "org"
#   - "lu"
# Plum API Interactions
PLUMISLAND: "https://localhost:5001"
PLUMAPIUSER: "myuser"
PLUMAPIPWD: "averystrongpasswordtochange"
